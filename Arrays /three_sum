# Brute

TC : O(N³ + V log M) (worst case O(N³ log N), commonly simplified to O(N³) in interviews and DSA discussions) 
Three nested loops: O(N³)
Sorting each valid triplet: O(1) (sorting only 3 elements)
Inserting into set: O(log M)
V = number of valid triplets found
M = number of unique triplets stored

SC : O(M)
Auxiliary space (excluding the output) is also O(M) because of the set

#include <bits/stdc++.h> 
vector<vector<int>> findTriplets(vector<int>arr, int n, int K) {
	
	set<vector<int>> st;

	for(int i=0; i<n; i++){
		for(int j=i+1; j<n; j++){
			for(int k=j+1; k<n; k++){
				if(arr[i] + arr[j] + arr[k] == K){
					vector<int> temp = {arr[i], arr[j], arr[k]};
					sort(temp.begin(), temp.end());
					st.insert(temp);
				}
			}
		}
	}
	vector<vector<int>> ans(st.begin(), st.end());
	return ans;
}



# Better 
TC : O(n² log n)
SC : 
Auxiliary Space: O(n)
Total Space (including output): O(n + m),
where m is the number of unique triplets (worst case O(n²))
Worst-case total space: O(n²)

#include <bits/stdc++.h> 
vector<vector<int>> findTriplets(vector<int>arr, int n, int K) {
	set<vector<int>> st;
	
	for(int i=0; i<n; i++){

		set<int> middleElements;

		for(int j=i+1; j<n; j++){

			int third = K - (arr[i] + arr[j]);
			if(middleElements.find(third) != middleElements.end()){
				vector<int> temp = {arr[i], arr[j], third};
				sort(temp.begin(), temp.end());
				st.insert(temp);
			}	
			middleElements.insert(arr[j]);
		}
	}

	vector<vector<int>> ans(st.begin(), st.end());
	return ans;
}



# Optimal
TC : O(n²)
SC : 
Total Space = O(1) + O(number of triplets)
Auxiliary Space = O(1)

class Solution {
public:
    vector<vector<int>> threeSum(vector<int>& nums) {

        sort(nums.begin(), nums.end());

        int n = nums.size();
        
        vector<vector<int>> ans;

        for(int i=0; i<n-2; i++){
            if(i>0 && nums[i] == nums[i-1]){
                continue;
            }

            int j = i + 1;
            int k = n - 1;

            while(j < k){
                long long sum = 1LL * nums[i] + nums[j] + nums[k];
                if(sum > 0){
                    k--;
                }
                else if(sum < 0){
                    j++;
                }
                else{
                    ans.push_back({nums[i], nums[j], nums[k]});

                    j++;
                    k--;
                    while(j<k && nums[j] == nums[j-1]){
                        j++;
                    }
                    while(j<k && nums[k] == nums[k+1]){
                        k--;
                    }
                }
            }
        }
        
        return ans;
    }
};




-- You are given an array ‘ARR’ containing ‘N’ integers, and you are also given an integer ‘TARGET’.
You task is to find the count of triplets i, j, k ( 0 ≤ i < j < k < N ), such that 'ARR[i]' + 'ARR[j]' + 'ARR[k]' is less than the value of ‘TARGET’.

# Brute
TC : O(n³)  (three nested loops)
SC : O(1)
#include <bits/stdc++.h>
using namespace std;

int threeSumSmaller(int n, vector<int> arr, int target) {

    int count = 0;

    for(int i = 0; i < n - 2; i++) {
        for(int j = i + 1; j < n - 1; j++) {
            for(int k = j + 1; k < n; k++) {

                if(arr[i] + arr[j] + arr[k] < target)
                    count++;
            }
        }
    }

    return count;
}


# Optimal
TC : O(n²)
SC : O(1)
#include <bits/stdc++.h> 
int threeSumSmaller(int n, vector<int> arr, int target) {
    sort(arr.begin(), arr.end());

    int count = 0;
    
    for(int i=0; i<n; i++){

        int j = i + 1;
        int k = n - 1;
        while(j < k){
            int sum = arr[i] + arr[j] + arr[k];
            if(sum < target){
                count += (k - j);

                j++;
            }
            else{
                k--;
            }
        }
    }

    return count;
}
