#include <bits/stdc++.h> 
vector<vector<int>> findTriplets(vector<int>arr, int n, int K) {
	set<vector<int>> st;
	
	for(int i=0; i<n; i++){

		set<int> middleElements;

		for(int j=i+1; j<n; j++){

			int third = K - (arr[i] + arr[j]);
			if(middleElements.find(third) != middleElements.end()){
				vector<int> temp = {arr[i], arr[j], third};
				sort(temp.begin(), temp.end());
				st.insert(temp);
			}	
			middleElements.insert(arr[j]);
		}
	}

	vector<vector<int>> ans(st.begin(), st.end());
	return ans;
}
