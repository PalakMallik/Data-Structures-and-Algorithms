# Brute 

TC : O(n²)
SC : O(1)

class Solution {
  public:

    // Function to return length of longest subsequence of consecutive integers.
    int longestConsecutive(vector<int>& arr) {

        int n = arr.size();
        if(n == 0) return 0;
        int longest = 1;
        
        for(int i=0; i<n; i++){
            int x = arr[i];
            int count = 1;
            
            while(find(arr.begin(), arr.end(), x+1) != arr.end()){
                x = x + 1;
                count++;
            }
             
            longest = max(longest, count);   
        }
        
        return longest;
    }
};


# Better 

1. Sort array
2. Traverse and count consecutive elements
3. Ignore duplicates

TC : O(n log n)
SC : O(1) (ignoring sorting space)

class Solution {
  public:

    // Function to return length of longest subsequence of consecutive integers.
    int longestConsecutive(vector<int>& arr) {
        int n = arr.size();
        
        if(n == 1) return 1;
        
        sort(arr.begin(), arr.end());
        
        int longest = 1;
        int count = 1;

        for(int i=1; i<n; i++){
            if(arr[i] == arr[i-1] + 1){
                count++;
            }
            
            else if(arr[i] == arr[i-1]){
                continue;
            }
            
            else{
                count = 1;
            }
            
            longest = max(longest, count);
        }
        
        return longest;
    }
};


