# Brute 
TC : O(n³)
SC : O(1)
class Solution {
	public:
	long subarrayXor(vector<int> &arr, int k) {
		int n = arr.size();
		long count = 0;
		
		for (int i = 0; i<n; i++) {
			for (int j = i; j<n; j++) {
				
				int xr = 0;
				
				for (int idx = i; idx <= j; idx++) {
					xr = xr ^ arr[idx];
				}
				
				if (xr == k) {
					count++;
				}
			}
		}
		
		return count;
	}
};




