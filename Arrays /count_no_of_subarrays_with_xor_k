# Optimal
TC : O(n)
SC : O(n)
class Solution {
  public:
    long subarrayXor(vector<int> &arr, int k) {
        int n = arr.size();
        long count = 0;
        int prefixXOR = 0;
        
        unordered_map<int, int> hashMap;
        hashMap[0] = 1;
        
        for(int i=0; i<n; i++){
            prefixXOR ^= arr[i];
            
            int x = prefixXOR ^ k;
            
            if(hashMap.find(x) != hashMap.end()){
                count += hashMap[x];
            }
            
            hashMap[prefixXOR]++;
        }
        
        return count;
    }
};
