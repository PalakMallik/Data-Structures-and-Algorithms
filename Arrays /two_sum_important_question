Problem statement
You are given an array of integers 'ARR' of length 'N' and an integer Target. Your task is to return all pairs of elements such that they add up to Target.

Note:  We cannot use the element at a given index twice.
Detailed explanation ( Input/output format, Notes, Images )
Constraints:
1 ≤ n ≤ 105
1 ≤ arr[i] ≤ 105



#include <bits/stdc++.h>
using namespace std;

vector<pair<int,int>> twoSum(vector<int>& arr, int target, int n)
{

    // TC :  O(N log N)
    // SC :  O(1) extra space (excluding the output vector)
    // If you include the output vector, then:
    // Space Complexity: O(k)
    // where k = number of pairs stored in ans.

    sort(arr.begin(), arr.end());
    vector<pair<int, int>> ans;
    int left = 0, right = n-1;

    while(left < right){
        int sum = arr[left] + arr[right];

        if(sum < target){
            left++;
        }

        else if(sum > target){
            right--;
        }

        else{
            ans.push_back({arr[left],arr[right]});
            left++;
            right--;
        }
    }

    if(ans.empty()) return {{-1, -1}};
    return ans;
}


Follow Up:  Try to do this problem in O(N) time complexity. 

unordered_map<int, int> freq;
vector<pair<int,int>> ans;

for(int x : arr){
    int rem = target - x;

    if(freq[rem] > 0){
        for(int i = 0; i < freq[rem]; i++){
            ans.push_back({min(x, rem), max(x, rem)});
        }
    }

    freq[x]++;
}

Time: O(N + k)
Space: O(N)
