# IMPORTANT QUESTION

Brute force

this solution is completely correct even if the array contains:
positive numbers
negative numbers
zeros
Because you are checking every possible subarray

TC = O(n²)
SC = O(1)

int longestSubarrayWithSumK(vector<int> a, long long k) {

    int maxLength = 0;
    for(int i=0; i<a.size(); i++){
        long long sum = 0;
        for(int j=i; j<a.size(); j++){
            sum += a[j];

            if(sum == k){
                maxLength = max(maxLength, (j-i+1));
            }
        }
    }
    return maxLength;
}



# Better solution
sliding window (two pointers) approach
(this is optimal solution for array containing only non-negative elements)

Time: O(n)  Even though there is a while loop inside the for loop, the left pointer never moves backward.
                So total movements:
                    right → n times
                    left  → n times
                    Overall:
                    O(n + n) = O(n)
Space: O(1)

int longestSubarray(vector<int>& nums, int k) {
    int left = 0, sum = 0, maxLength = 0;

    for (int right = 0; right < nums.size(); right++) {
        sum += nums[right];

        while (sum > k && left <= right) {
            sum -= nums[left];
            left++;
        }

        if (sum == k) {
            maxLength = max(maxLength, right - left + 1);
        }
    }

    return maxLength;
}



# Optimal 
Prefix Sum + HashMap (best for any array containing +ve, -ve and/or 0s)
TC: O(n) average
SC: O(n)

class Solution {
  public:
    int longestSubarray(vector<int>& arr, int k) {

        unordered_map<long long, int> mpp;
        int maxLength = 0;
        long long prefixSum = 0;
        int n = arr.size();
        
        for(int i=0; i<n; i++){
            prefixSum += arr[i];
            
            if(prefixSum == k){
                maxLength = max(maxLength, i+1);
            }
            
            long long rem = prefixSum - k;
            
            if(mpp.find(rem) != mpp.end()){
                maxLength = max(maxLength, i-mpp[rem]);
            }
            
            if(mpp.find(prefixSum) == mpp.end()){
                mpp[prefixSum] = i;
            }
        }
        return maxLength;
    }
};
