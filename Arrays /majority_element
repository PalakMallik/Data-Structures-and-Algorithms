# Brute force algorithm
Nested loop

TC : O(n²)
SC : O(1)

int majorityElement(vector<int> v) {
	// Brute force approach
	for(int i=0; i<v.size(); i++){
        int count = 0;
        for(int j=0; j<v.size(); j++){
            if(v[j] == v[i]){
                count++;
            }
        }
        if(count > (v.size() / 2)){
            return v[i];
        }
    }
}




# Better approach
Frequency Counting / Hashing Approach

TC : O(n log n)
SC : O(n)

class Solution {
  public:
    int majorityElement(vector<int>& arr) {
        // Better approach
        int n = arr.size();
        map<int, int> freq;
        for(auto value : arr){
            freq[value]++;
        }
        
        for(auto x : freq){
            if(x.second > n/2){
                return x.first;
            }
        }
        
        return -1;
    }
};


