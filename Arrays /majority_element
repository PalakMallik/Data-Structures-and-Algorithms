# Brute force algorithm
Nested loop

TC : O(n²)
SC : O(1)

int majorityElement(vector<int> v) {
	// Brute force approach
	for(int i=0; i<v.size(); i++){
        int count = 0;
        for(int j=0; j<v.size(); j++){
            if(v[j] == v[i]){
                count++;
            }
        }
        if(count > (v.size() / 2)){
            return v[i];
        }
    }
}


# Better approach
Frequency Counting / Hashing Approach

TC : O(n log n)
SC : O(n)

class Solution {
  public:
    int majorityElement(vector<int>& arr) {
        // Better approach
        int n = arr.size();
        map<int, int> freq;
        for(auto value : arr){
            freq[value]++;
        }
        
        for(auto x : freq){
            if(x.second > n/2){
                return x.first;
            }
        }
        
        return -1;
    }
};

# Optimal approach
Boyer–Moore majority vote algorithm

TC : O(n)
SC : O(1)

class Solution {
public:
    int majorityElement(vector<int>& nums) {
        int n = nums.size();
        int count = 0;
        int element;
        for(int i=0; i<n; i++){
            if(count == 0){
                element = nums[i];
                count++;
            }
            else if(nums[i] == element){
                count++;
            }
            else{
                count--;
            }
        }
        return element;
    }
};

If the problem does not guarantee that a mojority element exists, then run a second loop to confirm if the candidate element is actually present in majority or not.
