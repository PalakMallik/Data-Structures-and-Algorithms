# Optimal       (in-place modification,  no extra space)

-- Rotate matrix by 90° clockwise            (transpose and reverse each row)
TC : O(n²)
SC : O(1)

class Solution {
public:
    void rotate(vector<vector<int>>& matrix) {
        int n = matrix.size();

        for(int i=0; i<n; i++){                                // Transpose
            for(int j=i+1; j<n; j++){
                swap(matrix[i][j], matrix[j][i]);
            }
        }

        for(int i=0; i<n; i++){                                // Reverse each row
            reverse(matrix[i].begin(), matrix[i].end());
        }
    }
};

-- Rotate matrix by 90° anti-clockwise        (transpose and reverse each column)
TC : O(n²)
SC : O(1)

#include <bits/stdc++.h> 
vector<vector<int>> rotateMatrix(vector<vector<int>> &matrix)
{
    int n = matrix.size();

    for(int i=0; i<n; i++){                               // Transpose
        for(int j=i+1; j<n; j++){
            swap(matrix[i][j], matrix[j][i]);
        }
    }

    for(int j=0; j<n; j++){
        int top = 0;
        int bottom = n-1;

        while(top < bottom){
            swap(matrix[top][j], matrix[bottom][j]);      // Reverse each column
            top++;
            bottom--;
        }
    }

    return matrix;
}
