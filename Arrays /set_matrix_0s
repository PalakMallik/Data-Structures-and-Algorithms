# Brute force approach

TC : O(nm(n+m))  ≈  n³
SC : O(1)

#include <bits/stdc++.h>

void setZeros(vector<vector<int>> &matrix)
{
	int n = matrix.size();
	int m = matrix[0].size();

	auto setRowNeg1 = [&](int x)                      // lambda function
	{
		for(int j=0; j<m; j++){
			if(matrix[x][j] != 0){
				matrix[x][j] = -1;
			}
		}
	};

	auto setColumnNeg1 = [&](int x)                   // lambda function
	{
		for(int i=0; i<n; i++){
			if(matrix[i][x] != 0){
				matrix[i][x] = -1;
			}
		}
	};

	for(int i=0; i<n; i++){
		for(int j=0; j<m; j++){
			if(matrix[i][j] == 0){
				setRowNeg1(i);
				setColumnNeg1(j);
			}
		}
	}

	for(int i=0; i<n; i++){
		for(int j=0; j<m; j++){
			if(matrix[i][j] == -1){
				matrix[i][j] = 0;
			}
		}
	}
	
}



# Better approach

TC : O(n × m)
SC : O(n + m)

#include <bits/stdc++.h>

void setZeros(vector<vector<int>> &A) {
	int n11 = A.size();
	int n12 = A[0].size();

    vector <int> rows(n11, 0);
    vector <int> cols(n12, 0);
    
    for(int i=0; i<n11; i++){
        for(int j=0; j<n12; j++){
            if(A[i][j] == 0){
                rows[i] = 1;
                cols[j] = 1;
            }
        }
    }
    
    for(int i=0; i<n11; i++){
        for(int j=0; j<n12; j++){
            if(rows[i] || cols[j]){
                A[i][j] = 0;
            }
        }
    }
}



# Optimal 

TC : O(n × m)
SC : O(1)

class Solution {
public:
    void setZeroes(vector<vector<int>>& matrix) {
        int n = matrix.size();
        int m = matrix[0].size();
        int col0 = 1;

        // Step-1 : Mark rows and columns
        for(int i=0; i<n; i++){
            if(matrix[i][0] == 0){
                col0 = 0;
            }
            for(int j=1; j<m; j++){
                if(matrix[i][j] == 0){
                    matrix[i][0] = 0;
                    matrix[0][j] = 0;
                }
            }
        }

        // Step-2 : Set elements to 0 using markers
        for(int i=1; i<n; i++){
            for(int j=1; j<m; j++){
                if(matrix[0][j] == 0 || matrix[i][0] == 0){
                    matrix[i][j] = 0;
                }
            }
        }

        // Step-3 : Handle first row
        if(matrix[0][0] == 0){
            for(int i=1; i<m; i++){
                matrix[0][i] = 0;
            }
        }

        // Step-4 : Handle first column
        if(col0 == 0){
            for(int i=0; i<n; i++){
                matrix[i][0] = 0;
            }
        }
    }
};
