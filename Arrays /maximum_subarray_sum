# Brute force

Time Complexity: O(n³)  → Three nested loops
Space Complexity: O(1)  → No extra space used

long long maxSubarraySum(vector<int> arr, int n)
{
    // Brute force
    long long maximumSum = 0;
    for(int i=0; i<n; i++){
        for(int j=i; j<n; j++){
            long long sum = 0;
            for(int k=i; k<=j; k++){
                sum += arr[k];
            }
            maximumSum = max(maximumSum, sum);
        }
    }
    return maximumSum;
}
