# Brute force

TC: O(n³)  → Three nested loops
SC: O(1)  → No extra space used

long long maxSubarraySum(vector<int> arr, int n)
{
    // Brute force
    long long maximumSum = LLONG_MIN;
    for(int i=0; i<n; i++){
        for(int j=i; j<n; j++){
            long long sum = 0;
            for(int k=i; k<=j; k++){
                sum += arr[k];
            }
            maximumSum = max(maximumSum, sum);
        }
    }
    return maximumSum;
}



# Better brute 

TC: O(n²)
SC: O(1)

long long maxSubarraySum(vector<int> arr, int n)
{
    // Better approach
    long long maximumSum = LLONG_MIN;
    for(int i=0; i<n; i++){
        long long sum = 0;
        for(int j=i; j<n; j++){
            sum += arr[j];
            
            maximumSum = max(maximumSum, sum);
        }
    }
    return maximumSum;
}



# Optimal 

TC : O(n)
SC : O(1)

class Solution {
public:
    int maxSubArray(vector<int>& nums) {
        if(nums.empty()) return 0;
        int n = nums.size();
        int currentSum = nums[0];
        int maximumSum = nums[0];
        for(int i=1; i<n; i++){
            currentSum = max(nums[i], currentSum + nums[i]);
            maximumSum = max(maximumSum, currentSum);
        }
        return maximumSum;
    }
};
