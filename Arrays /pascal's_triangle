-- Print element at given row and column in Pascal's triangle

TC : O(col)
SC : O(1)

#include <bits/stdc++.h>
using namespace std;

int element(int row, int col)
{
    int n = row - 1;
    int r = col - 1;

    long long res = 1;

    for (int i = 0; i < r; i++)
    {
        res = res * (n - i);
        res = res / (i + 1);
    }
    
    return res;
}

int main()
{
    cout << element(5, 3) << endl;
    return 0;
}





-- find nth row of Pascal's triangle

# Brute

TC : O(n²)
SC : O(n)
Auxiliary computation space is constant.

class Solution {
  public:
    int getElement(int row, int column){
            long long val = 1;
            
            int n = row - 1;
            int r = column - 1;
            
            r = min(r, n-r);
            
            for(int i=0; i<r; i++){
                val = val * (n - i);
                val = val / (i + 1);
            }
            
            return val;
        }
        
    vector<int> nthRowOfPascalTriangle(int n) {
        vector<int> ansRow;
        
        for(int col=1; col<=n; col++){
            ansRow.push_back(getElement(n, col));
        }
        
        return ansRow;
    }
};


# Optimal

TC : O(rowIndex)
SC : O(rowIndex)
Auxiliary Space = O(1)

class Solution {
public:
    vector<int> getRow(int rowIndex) {
        long long ans = 1;
        vector<int> ansRow(rowIndex + 1);
        ansRow[0] = 1;

        for(int col=1; col<=rowIndex; col++){
            ans = ans * (rowIndex - col + 1);
            ans = ans / (col);
            
            ansRow[col] = ans;
        }

        return ansRow;
    }
};






-- find first n rows of Pascal's triangle

# Brute 

TC : O(N³)
SC : O(N²)
Auxiliary Space (extra space excluding output) : O(N)

int getElement(int row, int column){
    int ans = 1;

    int n = row - 1;
    int r = column - 1;

    r = min(r, n-r);

    for(int i=0; i<r; i++){
        ans = ans * (n - i);
        ans = ans / (i + 1);
    }

    return ans;
}

vector<vector<int>> pascalTriangle(int N) {

    vector<vector<int>> pascalTriangle;

    for(int row=1; row<=N; row++){

        vector<int> ansRow;

        for(int col=1; col<=row; col++){
            ansRow.push_back(getElement(row, col));
        }

        pascalTriangle.push_back(ansRow);
    }

    return pascalTriangle;
}


# Optimal

TC : O(numRows²)
SC : O(numRows²)
Auxiliary Space: O(numRows)

class Solution {
public:
    vector<int> getRow(int row){
        int ans = 1;
        vector<int> ansRow;
        ansRow.push_back(ans);

        for(int col=1; col<row; col++){
            ans = ans * (row - col);
            ans = ans / (col);
            ansRow.push_back(ans);
        }

        return ansRow;
    }
    vector<vector<int>> generate(int numRows) {
        vector<vector<int>> pascalTriangle;

        for(int row=1; row<=numRows; row++){
            pascalTriangle.push_back(getRow(row));
        } 

        return pascalTriangle;
    }
};
