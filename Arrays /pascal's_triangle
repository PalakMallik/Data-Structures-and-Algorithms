-- Print element at given row and column in Pascal's triangle

TC : O(col)
SC : O(1)

#include <bits/stdc++.h>
using namespace std;

int element(int row, int col)
{
    int n = row - 1;
    int r = col - 1;

    int ans = 1;

    for (int i = 0; i < r; i++)
    {
        ans = ans * (n - i);
        ans = ans / (i + 1);
    }
    
    return ans;
}

int main()
{
    cout << element(5, 3) << endl;
    return 0;
}
