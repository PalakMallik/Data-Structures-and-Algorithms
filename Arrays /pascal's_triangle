int getElement(int row, int column){
    int ans = 1;

    int n = row - 1;
    int r = column - 1;

    r = min(r, n-r);

    for(int i=0; i<r; i++){
        ans = ans * (n - i);
        ans = ans / (i + 1);
    }

    return ans;
}

vector<vector<int>> pascalTriangle(int N) {

    vector<vector<int>> pascalTriangle;

    for(int row=1; row<=N; row++){

        vector<int> ansRow;

        for(int col=1; col<=row; col++){
            ansRow.push_back(getElement(row, col));
        }

        pascalTriangle.push_back(ansRow);
    }

    return pascalTriangle;
}


# Optimal

TC : O(numRows²)
SC : O(numRows²)
Auxiliary Space: O(numRows)

class Solution {
public:
    vector<int> getRow(int row){
        int ans = 1;
        vector<int> ansRow;
        ansRow.push_back(ans);

        for(int col=1; col<row; col++){
            ans = ans * (row - col);
            ans = ans / (col);
            ansRow.push_back(ans);
        }

        return ansRow;
    }
    vector<vector<int>> generate(int numRows) {
        vector<vector<int>> pascalTriangle;

        for(int row=1; row<=numRows; row++){
            pascalTriangle.push_back(getRow(row));
        } 

        return pascalTriangle;
    }
};
