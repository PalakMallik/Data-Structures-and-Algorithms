-- Print element at given row and column in Pascal's triangle

TC : O(col)
SC : O(1)

#include <bits/stdc++.h>
using namespace std;

int element(int row, int col)
{
    int n = row - 1;
    int r = col - 1;

    long long res = 1;

    for (int i = 0; i < r; i++)
    {
        res = res * (n - i);
        res = res / (i + 1);
    }
    
    return res;
}

int main()
{
    cout << element(5, 3) << endl;
    return 0;
}



